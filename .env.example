# =============================================
# 빵맵 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 실제 키 입력
# =============================================

# ----- Supabase (필수 - 인증/DB) -----
# https://supabase.com → 프로젝트 생성 → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----- 네이버 API (선택 - 전국 빵집 검색) -----
# https://developers.naver.com → 애플리케이션 등록 → 지역검색 API
VITE_NAVER_CLIENT_ID=your_naver_client_id
VITE_NAVER_CLIENT_SECRET=your_naver_client_secret

# ----- Google AdSense (선택 - 광고 수익) -----
# https://adsense.google.com → 사이트 추가 → 광고 단위 ID
VITE_ADSENSE_CLIENT_ID=ca-pub-your-adsense-id
VITE_ADSENSE_SLOT_RIGHT=your-right-sidebar-slot-id
VITE_ADSENSE_SLOT_BOTTOM=your-bottom-banner-slot-id

# ----- 카카오 지도 API (선택 - 네이티브 지도) -----
# https://developers.kakao.com → 앱 만들기 → JavaScript 키
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key
